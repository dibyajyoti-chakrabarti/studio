
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information, role, and vendor-specific specializations.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "teamName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "vendor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboarded": { "type": "boolean" },
        "specializations": { "type": "array", "items": { "type": "string" }, "description": "Vendor specializations like CNC, Laser, etc." },
        "location": { "type": "string", "description": "City, State, Country" },
        "experienceYears": { "type": "number" },
        "rating": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "portfolio": { "type": "string", "description": "Links or description of past works." },
        "imageUrl": { "type": "string", "description": "Data URI or URL for the profile logo/image." },
        "workshopImages": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs or Data URIs for workshop photos." },
        "adminNotes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["fullName", "email", "role", "onboarded"]
    },
    "RFQ": {
      "title": "RFQ",
      "description": "Represents a manufacturing request for quotation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "teamName": { "type": "string" },
        "projectName": { "type": "string" },
        "manufacturingProcess": { "type": "string" },
        "material": { "type": "string" },
        "quantity": { "type": "number" },
        "surfaceFinish": { "type": "string" },
        "tolerance": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "budgetRange": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "selectedVendors": { "type": "array", "items": { "type": "string" }, "description": "Names of selected vendors." },
        "selectedVendorIds": { "type": "array", "items": { "type": "string" }, "description": "UIDs of selected vendors." },
        "vendorId": { "type": "string", "description": "The ID of the vendor who eventually won the bid." },
        "designFileUrl": { "type": "string" },
        "designFileName": { "type": "string" },
        "status": { "type": "string", "enum": ["rfq_submitted", "quotation_sent", "negotiation", "order_confirmed", "shipping", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "manufacturingProcess", "material", "quantity", "status", "createdAt"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "Quotation for an RFQ with negotiation history.",
      "type": "object",
      "properties": {
        "rfqId": { "type": "string" },
        "userId": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "vendorRating": { "type": "number" },
        "quotedPrice": { "type": "number" },
        "leadTimeDays": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "negotiating", "accepted", "rejected"] },
        "negotiationHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "party": { "type": "string", "enum": ["user", "vendor", "admin"] },
              "price": { "type": "number" },
              "leadTime": { "type": "number" },
              "message": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rfqId", "userId", "vendorId", "quotedPrice", "leadTimeDays", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/rfqs/{rfqId}": {
      "schema": { "$ref": "#/backend/entities/RFQ" },
      "description": "Manufacturing requests."
    },
    "/quotations/{quotationId}": {
      "schema": { "$ref": "#/backend/entities/Quotation" },
      "description": "Quotations submitted by vendors."
    }
  }
}
