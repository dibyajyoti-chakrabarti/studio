
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information and their role.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "teamName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "vendor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboarded": { "type": "boolean" }
      },
      "required": ["fullName", "email", "role", "onboarded"]
    },
    "RFQ": {
      "title": "RFQ",
      "description": "Represents a manufacturing request for quotation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "teamName": { "type": "string" },
        "projectName": { "type": "string" },
        "manufacturingProcess": { "type": "string" },
        "material": { "type": "string" },
        "quantity": { "type": "number" },
        "surfaceFinish": { "type": "string" },
        "tolerance": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "budgetRange": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "selectedVendors": { "type": "array", "items": { "type": "string" } },
        "vendorId": { "type": "string" },
        "designFileUrl": { "type": "string", "description": "Data URI or storage link for the design file." },
        "designFileName": { "type": "string" },
        "status": { "type": "string", "enum": ["rfq_submitted", "quotation_sent", "negotiation", "order_confirmed", "shipping", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "manufacturingProcess", "material", "quantity", "status", "createdAt"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "Quotation for an RFQ.",
      "type": "object",
      "properties": {
        "rfqId": { "type": "string" },
        "userId": { "type": "string" },
        "vendorId": { "type": "string" },
        "quotedPrice": { "type": "number" },
        "leadTimeDays": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rfqId", "userId", "quotedPrice", "leadTimeDays", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/rfqs/{rfqId}": {
      "schema": { "$ref": "#/backend/entities/RFQ" },
      "description": "Manufacturing requests."
    },
    "/quotations/{quotationId}": {
      "schema": { "$ref": "#/backend/entities/Quotation" },
      "description": "Quotations."
    }
  }
}
