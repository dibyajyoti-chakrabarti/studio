{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores unified user information with specific fields for MechMasters.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "teamName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "vendor", "admin"] },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "specializations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Vendor capabilities."
        },
        "location": { "type": "string" },
        "experienceYears": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "portfolio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "assignedProjectsCount": { "type": "number" }
      },
      "required": ["fullName", "email", "role", "status", "onboarded"]
    },
    "RFQ": {
      "title": "RFQ",
      "description": "The central manufacturing request document.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "projectName": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "submitted",
            "quotations_received",
            "under_negotiation",
            "assigned",
            "in_progress",
            "completed",
            "cancelled"
          ]
        },
        "manufacturingProcess": { "type": "string" },
        "material": { "type": "string" },
        "quantity": { "type": "number" },
        "surfaceFinish": { "type": "string" },
        "tolerance": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "deliveryLocation": { "type": "string" },
        "budgetRange": { "type": "string" },
        "designFileUrl": { "type": "string" },
        "designFileName": { "type": "string" },
        "selectedVendorIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Vendors invited by user."
        },
        "shortlistedVendorIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Vendors approved by admin."
        },
        "assignedVendorId": { "type": "string", "description": "Final vendor winning the bid." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "userId",
        "projectName",
        "status",
        "manufacturingProcess",
        "material",
        "quantity",
        "createdAt"
      ]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "A specific vendor's bid for an RFQ.",
      "type": "object",
      "properties": {
        "rfqId": { "type": "string" },
        "vendorId": { "type": "string" },
        "userId": { "type": "string" },
        "vendorName": { "type": "string" },
        "quotedPrice": { "type": "number" },
        "leadTimeDays": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "revised", "accepted", "rejected"] },
        "negotiationHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "party": { "type": "string", "enum": ["customer", "vendor", "admin"] },
              "price": { "type": "number" },
              "leadTime": { "type": "number" },
              "message": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rfqId", "vendorId", "quotedPrice", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Feedback submitted after project completion.",
      "type": "object",
      "properties": {
        "rfqId": { "type": "string" },
        "vendorId": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rfqId", "vendorId", "rating", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "message", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/rfqs/{rfqId}": {
      "schema": { "$ref": "#/backend/entities/RFQ" },
      "description": "Manufacturing requests."
    },
    "/quotations/{quotationId}": {
      "schema": { "$ref": "#/backend/entities/Quotation" },
      "description": "Quotations submitted by vendors."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/backend/entities/Review" },
      "description": "Post-project reviews."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/backend/entities/Notification" },
      "description": "User notifications."
    }
  }
}
