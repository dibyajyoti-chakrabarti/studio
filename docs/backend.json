
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores detailed profile information for a MechHub user.",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "teamName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboarded": { "type": "boolean" }
      },
      "required": ["fullName", "email", "phone", "teamName", "onboarded"]
    },
    "RFQ": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RFQ",
      "type": "object",
      "description": "Represents a manufacturing request for quotation.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "teamName": { "type": "string" },
        "manufacturingProcess": { "type": "string" },
        "material": { "type": "string" },
        "quantity": { "type": "number" },
        "surfaceFinish": { "type": "string" },
        "tolerance": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "budgetRange": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "selectedVendors": { "type": "array", "items": { "type": "string" } },
        "fileURL": { "type": "string" },
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["rfq_submitted", "quotation_sent", "confirmed", "in_production", "completed"] },
        "quotationId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "manufacturingProcess", "material", "quantity", "status", "createdAt"]
    },
    "Quotation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quotation",
      "type": "object",
      "description": "Admin created quotation for an RFQ.",
      "properties": {
        "rfqId": { "type": "string" },
        "userId": { "type": "string" },
        "quotedPrice": { "type": "number" },
        "leadTimeDays": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rfqId", "userId", "quotedPrice", "leadTimeDays", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/rfqs/{rfqId}": {
      "schema": { "$ref": "#/backend/entities/RFQ" },
      "description": "Manufacturing requests."
    },
    "/quotations/{quotationId}": {
      "schema": { "$ref": "#/backend/entities/Quotation" },
      "description": "Admin quotations."
    }
  }
}
