
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Consultation Requests ---
    match /consultationRequests/{requestId} {
      allow get, list: if isAdmin();
      allow create: if true; // Public submission allowed
      allow update, delete: if isAdmin();
    }

    // --- RFQs (Manufacturing Requests) ---
    match /rfqs/{rfqId} {
      // Allow users to list and get their own RFQs based on the userId field.
      // The client query must filter by 'userId' to satisfy this rule.
      allow list: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      
      // Allow creation for any user (the app assigns the userId field)
      allow create: if true; 
      
      // Only owner or admin can update/delete
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
