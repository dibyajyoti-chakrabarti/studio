
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- RFQs ---
    match /rfqs/{rfqId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || (isOwner(resource.data.userId) && request.resource.data.status in ['rfq_submitted', 'confirmed']));
      allow delete: if isAdmin();
    }

    // --- Quotations ---
    match /quotations/{quotationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow write: if isAdmin();
    }

    // Support for other root collections (e.g. consultation requests)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
