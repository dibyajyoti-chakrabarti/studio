
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // Helper Functions
    // ─────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isVendor() {
      return isAuthenticated() && getUserData().role == 'vendor';
    }

    function isCustomer() {
      return isAuthenticated() && getUserData().role == 'customer';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────
    // users/{userId}
    // ─────────────────────────────────────────
    match /users/{userId} {
      // Public: read active vendor cards for landing page (unauthenticated ok)
      // Authenticated: any logged-in user can read any profile
      allow read: if (resource != null && resource.data.role == 'vendor' && resource.data.isActive == true)
                  || isAuthenticated();

      // Users can create their own profile on registration
      allow create: if isAuthenticated() && isOwner(userId);

      // User updates own profile; admin can update anyone (e.g. verify vendor)
      allow update: if isOwner(userId) || isAdmin();

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // rfqs/{rfqId}
    // ─────────────────────────────────────────
    match /rfqs/{rfqId} {
      allow read: if isAuthenticated() && (
        // Customer who owns the RFQ
        resource.data.userId == request.auth.uid ||
        // Admin has full visibility
        isAdmin() ||
        // Vendor shortlisted on this RFQ
        (isVendor() && (
          request.auth.uid in resource.data.shortlistedVendorIds ||
          request.auth.uid == resource.data.assignedVendorId
        ))
      );

      // Any authenticated user can submit an RFQ, but must set their own userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() && (
        // Owner can update their own RFQ (e.g. edit before submission)
        resource.data.userId == request.auth.uid ||
        // Admin can update anything (status, assignment, shortlist)
        isAdmin() ||
        // Assigned vendor can update production status
        (isVendor() && request.auth.uid == resource.data.assignedVendorId)
      );

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // projectRFQs/{projectId}
    // ─────────────────────────────────────────
    match /projectRFQs/{projectId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      // User must set their own userId when creating
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // projectParts/{partId}
    // ─────────────────────────────────────────
    match /projectParts/{partId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      // User must set their own userId when creating
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    // ─────────────────────────────────────────
    // quotations/{quotationId}
    // ─────────────────────────────────────────
    match /quotations/{quotationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );

      // Only vendors or admins can create quotations
      allow create: if isVendor() || isAdmin();

      allow update: if isAuthenticated() && (
        // Customer accepts/rejects; vendor revises their own quote
        resource.data.userId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // negotiations/{negotiationId}
    // ─────────────────────────────────────────
    match /negotiations/{negotiationId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isAuthenticated();

      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );

      allow delete: if isAdmin();

      // ── Subcollection: messages ──
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/negotiations/$(negotiationId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/negotiations/$(negotiationId)).data.vendorId == request.auth.uid ||
          isAdmin()
        );

        // Parties in the negotiation + admin can write messages
        allow create: if isAuthenticated() && (
          get(/databases/$(database)/documents/negotiations/$(negotiationId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/negotiations/$(negotiationId)).data.vendorId == request.auth.uid ||
          isAdmin()
        );

        // Messages are immutable after creation (no edits, no deletes by users)
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────
    // reviews/{reviewId}
    // ─────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public reviews readable by anyone for vendor profile pages
      allow read: if resource.data.isPublic == true || isAuthenticated();

      // Only the customer who completed the project can write a review
      allow create: if isAuthenticated() && isOwner(request.resource.data.customerId);

      // Only admin can edit/delete reviews
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // notifications/{notificationId}
    // ─────────────────────────────────────────
    match /notifications/{notificationId} {
      // User can read and mark-as-read their own notifications
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Only admin can create notifications (cloud functions handle this)
      allow create: if isAdmin();

      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ─────────────────────────────────────────
    // vendorCapabilities/{capabilityId}
    // ─────────────────────────────────────────
    match /vendorCapabilities/{capabilityId} {
      // Anyone authenticated can read capabilities (for RFQ matching)
      allow read: if isAuthenticated();

      // Vendor can manage their own capabilities; admin can manage any
      allow create: if (isVendor() && request.resource.data.vendorId == request.auth.uid) || isAdmin();
      allow update, delete: if (isVendor() && resource.data.vendorId == request.auth.uid) || isAdmin();
    }

    // ─────────────────────────────────────────
    // consultationRequests/{requestId}
    // ─────────────────────────────────────────
    match /consultationRequests/{requestId} {
      // Public submissions (unauthenticated contact form)
      allow create: if true;

      // Only admin reads and manages leads
      allow read, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // contactQueries/{queryId}
    // ─────────────────────────────────────────
    match /contactQueries/{queryId} {
      // Public submissions (unauthenticated contact form)
      allow create: if true;

      // Only admin reads and manages contact queries
      allow read, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // newsletter_subscribers/{docId}
    // ─────────────────────────────────────────
    match /newsletter_subscribers/{docId} {
      // Public: anyone can subscribe (unauthenticated)
      allow create: if true;

      // Only admin can read and manage subscribers
      allow read, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // blog_stats/{slug}
    // ─────────────────────────────────────────
    match /blog_stats/{slug} {
      // Anyone can read blog stats (likes, views)
      allow read: if true;
      
      // Anyone authenticated can create/update stats (e.g. increment likes)
      allow create, update: if isAuthenticated();
      
      // Only admin can delete stats
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // blog_comments/{commentId}
    // ─────────────────────────────────────────
    match /blog_comments/{commentId} {
      // Anyone can read comments
      allow read: if true;

      // Any authenticated user can create a comment
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      // Only the comment author or an admin can delete it
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Comments are currently immutable (cannot be updated)
      allow update: if false;
    }

    // ─────────────────────────────────────────
    // products/{productId}
    // ─────────────────────────────────────────
    match /products/{productId} {
      // Public: anyone can view products in the shop
      allow read: if true;

      // Only admin can manage the catalogue
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // orders/{orderId}
    // ─────────────────────────────────────────
    match /orders/{orderId} {
      // Users can read their own orders; admin reads all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      // User must set their own userId when creating
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      // Only admin can update order status or delete
      allow update, delete: if isAdmin();
    }
    // ─────────────────────────────────────────
    // restockRequests/{requestId}
    // ─────────────────────────────────────────
    match /restockRequests/{requestId} {
      // Only authenticated users can create a request for themselves
      allow create: if isAuthenticated()
                    && request.resource.data.productId != null
                    && request.resource.data.userId == request.auth.uid;
      
      // Only admin can read and manage demand index
      allow read, update, delete: if isAdmin();
    }

  }
}
