
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the current user is an admin via their Firestore profile document
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
    }

    // RFQS COLLECTION
    match /rfqs/{rfqId} {

      // Any logged-in user can create RFQ
      allow create: if request.auth != null;

      // Allow read if:
      // 1. User owns the RFQ
      // OR
      // 2. User role is admin
      allow read: if request.auth != null
        && (
          (resource != null && request.auth.uid == resource.data.userId)
          ||
          isAdmin()
        );

      // Allow update only if admin (Note: Per instruction 5, owners might need update access for confirmation)
      allow update: if request.auth != null
        && (isAdmin() || (resource != null && request.auth.uid == resource.data.userId));

      allow delete: if request.auth != null && isAdmin();
    }

    // QUOTATIONS COLLECTION
    match /quotations/{quotationId} {
      allow read: if request.auth != null && (
        (resource != null && resource.data.userId == request.auth.uid) || isAdmin()
      );
      allow write: if request.auth != null && isAdmin();
    }

    // CONSULTATION REQUESTS
    match /consultationRequests/{id} {
      allow create: if true;
      allow read: if request.auth != null && isAdmin();
    }
  }
}
