
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Consultation Requests ---
    match /consultationRequests/{requestId} {
      allow get, list: if isAdmin();
      allow create: if true; // Public submission allowed
      allow update, delete: if isAdmin();
    }

    // --- RFQs (Manufacturing Requests) ---
    match /rfqs/{rfqId} {
      // Users can see their own RFQs, admins can see all
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Allow creation if user is signed in or it's a pending submission
      allow create: if true; 
      
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
