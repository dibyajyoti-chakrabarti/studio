
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }

    match /rfqs/{rfqId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') || 
        (hasRole('vendor') && (
          resource.data.status == 'rfq_submitted' || 
          resource.data.vendorId == request.auth.uid ||
          (request.auth.uid in resource.data.selectedVendorIds)
        ))
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') || 
        (hasRole('vendor') && (
          resource.data.status == 'rfq_submitted' || 
          resource.data.vendorId == request.auth.uid ||
          (request.auth.uid in resource.data.selectedVendorIds)
        ))
      );
      allow delete: if hasRole('admin');
    }

    match /quotations/{quotationId} {
      allow read: if isAuthenticated() && (
        (resource == null) || // For collection listing
        resource.data.userId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid ||
        hasRole('admin')
      );
      allow create: if isAuthenticated() && (hasRole('vendor') || hasRole('admin'));
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid ||
        hasRole('admin')
      );
    }

    match /consultationRequests/{id} {
      allow create: if true;
      allow read: if hasRole('admin');
    }
  }
}
