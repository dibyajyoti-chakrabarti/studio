rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // --- User Profiles ---
    match /users/{userId} {
      // User can read/write their own profile
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Inheritance rule for nested subcollections as requested
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- RFQs (Root Collection) ---
    match /rfqs/{rfqId} {
      allow create: if isSignedIn();
      // read/list is allowed if the user is an owner or an admin
      // Firestore list operations require a query filter to match this ownership rule
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    // --- Quotations ---
    match /quotations/{quotationId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow write: if isAdmin();
    }

    // Default deny for non-admin on other root paths
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}