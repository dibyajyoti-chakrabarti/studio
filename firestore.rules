rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user has a specific role
    function hasRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // RFQs (Manufacturing Requests)
    match /rfqs/{rfqId} {
      // Users see their own. Vendors see open marketplace or assigned. Admins see all.
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') || 
        (hasRole('vendor') && (resource.data.status == 'rfq_submitted' || resource.data.vendorId == request.auth.uid))
      );
      
      // Innovators create. Admins/Vendors update status.
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') || 
        (hasRole('vendor') && resource.data.vendorId == request.auth.uid)
      );
    }

    // Quotations
    match /quotations/{quotationId} {
      allow read, write: if request.auth != null;
    }

    // Consultation requests
    match /consultationRequests/{id} {
      allow create: if true;
      allow read: if hasRole('admin');
    }

  }
}