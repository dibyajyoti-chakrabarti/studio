
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- RFQs ---
    match /rfqs/{rfqId} {
      // Users can list and read their own RFQs
      allow list: if isSignedIn() && request.query.limit <= 100 && (
        isAdmin() || resource.data.userId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        isAdmin() || resource.data.userId == request.auth.uid
      );
      // Users can create RFQs, Admin can update status
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() || (isOwner(resource.data.userId) && request.resource.data.status == resource.data.status)
      );
      allow delete: if isAdmin();
    }

    // --- Quotations ---
    match /quotations/{quotationId} {
      allow read: if isSignedIn() && (
        isAdmin() || resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isAdmin();
    }

    // --- Admin Metadata ---
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
    
    // Legacy support for user sandbox subcollections
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
