
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common checks
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    // User profiles
    match /users/{userId} {
      // Public read for vendors so they show up in MatchingPage for guest/new users
      allow read: if isAuthenticated() || (resource != null && resource.data.role == 'vendor');
      allow write: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }

    // Manufacturing Requests (RFQs)
    match /rfqs/{rfqId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') || 
        (hasRole('vendor') && (
          resource.data.status == 'rfq_submitted' || 
          resource.data.vendorId == request.auth.uid ||
          (request.auth.uid in resource.data.selectedVendorIds)
        ))
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') || 
        (hasRole('vendor') && (
          resource.data.status == 'rfq_submitted' || 
          resource.data.vendorId == request.auth.uid ||
          (request.auth.uid in resource.data.selectedVendorIds)
        ))
      );
      allow delete: if hasRole('admin');
    }

    // Quotations and Bids
    match /quotations/{quotationId} {
      allow read: if isAuthenticated() && (
        // Allow listing if the user is part of the specific RFQ
        // In rule evaluation for 'list', resource is null, so we must rely on query filters
        // Firestore automatically validates that the query is restricted to these filters
        (resource == null) || 
        resource.data.userId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid ||
        hasRole('admin')
      );
      allow create: if isAuthenticated() && (hasRole('vendor') || hasRole('admin'));
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid ||
        hasRole('admin')
      );
    }

    // Expert Consultation Requests
    match /consultationRequests/{id} {
      allow create: if true; // Public lead generation
      allow read: if hasRole('admin');
    }
  }
}
