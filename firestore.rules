
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the current user is an admin via Firestore profile field
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow users to read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow admins to read any profile
      allow read: if isAdmin();
    }

    match /rfqs/{rfqId} {
      // Users can create RFQs for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Users can only read their OWN rfqs via filtered queries
      // Admins can read all (including list operations)
      allow read: if request.auth != null && (
        (resource != null && resource.data.userId == request.auth.uid) || isAdmin()
      );

      // Only owner or admin can update
      allow update: if request.auth != null && (
        (resource != null && resource.data.userId == request.auth.uid) || isAdmin()
      );

      // Only admin can delete
      allow delete: if isAdmin();
    }

    match /quotations/{quotationId} {
      // Users can read quotes sent to them
      allow read: if request.auth != null && (
        (resource != null && resource.data.userId == request.auth.uid) || isAdmin()
      );
      // Only admins can create/update quotations
      allow write: if isAdmin();
    }
  }
}
