rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users full access (DEV ONLY)
    // This resolves "Missing or insufficient permissions" errors caused by restrictive rules
    // or unverified emails (email_verified: false) during the listing of collections.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}